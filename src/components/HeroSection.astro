---
import { stats } from '../config/site';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-grid">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <!-- Gradient Orbs -->
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-accent-500/20 rounded-full blur-3xl animate-float-delayed"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/10 rounded-full blur-3xl animate-pulse-glow"></div>

    <!-- Floating Particles -->
    <div class="absolute top-20 left-1/4 w-2 h-2 bg-primary-400 rounded-full animate-float opacity-60"></div>
    <div class="absolute top-40 right-1/3 w-3 h-3 bg-accent-400 rounded-full animate-float-delayed opacity-40"></div>
    <div class="absolute bottom-32 left-1/3 w-2 h-2 bg-primary-300 rounded-full animate-float-slow opacity-50"></div>
    <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-accent-300 rounded-full animate-float opacity-60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-dark-800/50 border border-primary-600/30 backdrop-blur-sm mb-8 animate-slide-down">
      <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
      <span class="text-sm text-primary-200">Disponible para nuevos proyectos</span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-bold mb-6 animate-slide-up">
      <span class="block text-dark-100">Facilitador de</span>
      <span class="gradient-text">Soluciones Digitales</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-xl md:text-2xl text-dark-300 max-w-3xl mx-auto mb-12 text-balance animate-slide-up" style="animation-delay: 0.2s">
      Especialista en
      <span class="text-primary-400 font-semibold">Next.js 16</span>,
      <span class="text-accent-400 font-semibold">Laravel 12</span>,
      <span class="text-primary-300 font-semibold">NestJS</span> y
      <span class="text-accent-300 font-semibold">plataformas SaaS</span>
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 animate-slide-up" style="animation-delay: 0.4s">
      <a href="#proyectos" class="btn-primary text-lg">
        <span class="flex items-center gap-2">
          Ver Proyectos
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </span>
      </a>
      <a href="#contacto" class="btn-secondary text-lg">
        Contactar Ahora
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto animate-fade-in" style="animation-delay: 0.6s">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-display font-bold gradient-text mb-2">{stat.value}</div>
          <div class="text-dark-400 text-sm md:text-base">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a href="#servicios" class="flex flex-col items-center gap-2 text-dark-500 hover:text-primary-400 transition-colors" aria-label="Scroll down">
      <span class="text-xs">Scroll</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </a>
  </div>
</section>

<script>
  // Intersection Observer for scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
</script>

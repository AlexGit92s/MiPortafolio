---
import { siteConfig } from '../config/site';

const whatsappMessage = encodeURIComponent('Hola, me interesa iniciar un servicio de desarrollo web. ¿Podemos conversar?');
const whatsappNumber = siteConfig.phone.replace(/\s/g, '');
---

<a
  href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 left-6 z-50 w-14 h-14 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg shadow-green-500/30 hover:bg-green-600 hover:scale-110 transition-all duration-300"
  aria-label="Contactar por WhatsApp"
>
  <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8.013 8.013 0 01-4.16-1.168l-.252-.144-2.868.852.852-2.868-.144-.252A8.013 8.013 0 014 12a8 8 0 1116 0 8 8 0 01-8 8z" clip-rule="evenodd"/>
    <path d="M17.05 14.21c-.24-.12-1.56-.77-1.8-.86-.24-.09-.42-.12-.6.12-.18.24-.69.86-.85 1.03-.15.18-.3.21-.54.09-.24-.12-1.02-.37-1.94-1.18-.72-.63-1.2-1.41-1.34-1.65-.14-.24-.02-.37.11-.5.1-.11.24-.27.36-.41.12-.14.15-.24.24-.41.09-.18.05-.33-.02-.47-.07-.14-.6-1.44-.82-1.97-.22-.51-.44-.44-.6-.45l-.51-.01c-.18 0-.47.07-.72.33-.24.27-.93.91-.93 2.23 0 1.31.96 2.58 1.09 2.76.14.18 1.89 2.88 4.58 4.04.64.28 1.14.44 1.53.57.64.2 1.22.17 1.68.1.51-.08 1.56-.64 1.78-1.25.22-.61.22-1.13.15-1.25-.06-.12-.24-.18-.48-.3z"/>
  </svg>
</a>

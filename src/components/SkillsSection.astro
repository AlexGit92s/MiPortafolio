---
import { skillCategories } from '../config/site';
---

<section id="skills" class="relative py-24 bg-dark-950">
  <!-- Background -->
  <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-primary-600/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-accent-600/10 rounded-full blur-3xl"></div>

  <div class="relative section-container">
    <!-- Skills Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-2 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-400 text-sm font-medium mb-4">
        Tecnologías
      </span>
      <h2 class="section-title">
        Stack <span class="gradient-text">Tecnológico</span>
      </h2>
      <p class="section-subtitle">
        Domino un amplio ecosistema de tecnologías para ofrecer la mejor solución a cada desafío.
      </p>
    </div>

    <!-- Skills Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      {skillCategories.map((category, index) => (
        <div
          class="glass-card-hover p-6 animate-on-scroll"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <h3 class="text-lg font-display font-semibold text-white mb-4">{category.name}</h3>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="skill-tag px-3 py-1.5 text-sm rounded-lg bg-dark-700/50 text-dark-300 border border-dark-600/30 hover:bg-primary-500/20 hover:text-primary-400 hover:border-primary-500/30 transition-all duration-300 cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Skill Generator CTA -->
    <div class="text-center mt-16 animate-on-scroll">
      <a href="/skill-generator" class="group inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-primary-500/10 border border-primary-500/30 text-primary-400 font-semibold hover:bg-primary-500/20 hover:border-primary-500/50 transition-all duration-300">
        <span>⚡</span>
        <span>Ver Tutorial — Skill Generator CLI</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
